# 应用配置
APP_NAME=MicroBubble Agent
# APP_ENV: development | production（影响 CORS、SECRET_KEY 校验等行为）
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-this-to-a-random-string

# 数据库 (Docker 内部网络用 db:5432，宿主机用 localhost:5432)
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/microbubble
POSTGRES_PASSWORD=microbubble2026

# Redis (Docker 内部网络)
REDIS_URL=redis://redis:6379/0

# MinIO对象存储
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio2026secure
MINIO_BUCKET=microbubble
MINIO_SECURE=false

# 站点域名（用于构造头像等公网可访问的 URL）
SITE_DOMAIN=agent.mnb-lab.cn

# Claude API
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# 留空则使用各模块默认模型（代理服务需指定如 mimo-v2.5）
CLAUDE_MODEL=
# Claude 生成参数
CLAUDE_MAX_TOKENS=8192
SESSION_WINDOW_SIZE=30

# MiMo API (OpenAI 兼容，用于视觉等多模态功能)
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5

# 腾讯会议
TENCENT_MEETING_SDK_ID=your-sdk-id
TENCENT_MEETING_SDK_KEY=your-sdk-key
TENCENT_MEETING_USERID=your-user-id

# 企业微信
WECHAT_CORP_ID=your-corp-id
WECHAT_AGENT_ID=your-agent-id
WECHAT_SECRET=your-secret
WECHAT_CALLBACK_TOKEN=your-callback-token
WECHAT_ENCODING_AES_KEY=your-encoding-aes-key
# 企业微信 API 地址（本地开发直连，生产环境走云服务器代理）
WECHAT_API_BASE_URL=https://qyapi.weixin.qq.com
# 微信互通：外部联系人消息的发送者（填一个企业微信成员的userid）
WECHAT_EXTERNAL_SENDER=

# Whisper语音识别 (服务器无GPU用base+cpu，有GPU用large-v3+cuda)
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda
WHISPER_SERVICE_URL=http://whisper:8002

# HuggingFace 镜像源（国内网络建议设置）
HF_ENDPOINT=

# 数据库连接池
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# JWT 令牌有效期
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis 会话 TTL（秒，默认 48 小时）
SESSION_TTL=172800

# 文件上传大小限制（MB）
MAX_UPLOAD_SIZE_MB=50

# CORS 允许的额外源（逗号分隔，可选）
CORS_ORIGINS=

# 服务器
HOST=0.0.0.0
PORT=8000
