FROM python:3.11-slim-bookworm

# 阿里云镜像源 (bookworm-security 路径已正确支持)
RUN rm -f /etc/apt/sources.list.d/debian.sources /etc/apt/sources.list && \
    printf 'deb http://mirrors.aliyun.com/debian bookworm main contrib\n' > /etc/apt/sources.list && \
    printf 'deb http://mirrors.aliyun.com/debian bookworm-updates main contrib\n' >> /etc/apt/sources.list && \
    printf 'deb http://mirrors.aliyun.com/debian-security bookworm-security main contrib\n' >> /etc/apt/sources.list

# Install system dependencies (with retry for transient 502 Bad Gateway)
RUN apt-get update && apt-get install -y --fix-missing \
    ffmpeg \
    libavformat-dev \
    libavcodec-dev \
    libavdevice-dev \
    libavutil-dev \
    libavfilter-dev \
    libswscale-dev \
    libswresample-dev \
    pkg-config \
    || (apt-get update && apt-get install -y --fix-missing --no-install-recommends \
        ffmpeg libavformat-dev libavcodec-dev libavdevice-dev \
        libavutil-dev libavfilter-dev libswscale-dev libswresample-dev \
        pkg-config) \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 安装Python依赖 + CUDA运行时库（通过pip安装，避免下载大CUDA镜像）
RUN pip3 install --no-cache-dir --upgrade pip && \
    pip3 install --no-cache-dir --prefer-binary \
    faster-whisper==1.2.1 \
    nvidia-cublas-cu12 \
    nvidia-cuda-nvrtc-cu12 \
    fastapi uvicorn python-multipart

# 设置CUDA库路径
ENV LD_LIBRARY_PATH=/usr/local/lib/python3.11/site-packages/nvidia/cublas/lib:/usr/local/lib/python3.11/site-packages/nvidia/cuda_nvrtc/lib

# v31.3.1: 不再 COPY app/whisper_server.py 进镜像
# 改用 docker-compose.yml bind mount ./app/whisper_server.py:/app/whisper_server.py:ro
# 优势: 本地源码改动 → docker compose restart 即可生效, 不需要 rebuild 镜像
# (旧方案 Dockerfile COPY 烧进镜像 → 源码改动后必须 rebuild 才能看到, 违反 CLAUDE.md 7a 教训)

# 环境变量（可通过 docker-compose 覆盖）
ENV MODEL_SIZE=large-v3
ENV DEVICE=cuda

# 暴露端口
EXPOSE 8002

# 启动命令 - 使用自定义 FastAPI 服务
CMD ["python3", "whisper_server.py"]
