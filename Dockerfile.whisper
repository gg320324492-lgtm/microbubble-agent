FROM python:3.11-slim-bookworm

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    ffmpeg \
    libavformat-dev \
    libavcodec-dev \
    libavdevice-dev \
    libavutil-dev \
    libavfilter-dev \
    libswscale-dev \
    libswresample-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 安装Python依赖（使用预编译 wheel，避免 av 源码编译失败）
RUN pip3 install --no-cache-dir --upgrade pip && \
    pip3 install --no-cache-dir --prefer-binary faster-whisper==1.2.1 fastapi uvicorn python-multipart

# 复制 Whisper 服务端代码
COPY app/whisper_server.py .

# 环境变量（可通过 docker-compose 覆盖）
ENV MODEL_SIZE=base
ENV DEVICE=cpu

# 暴露端口
EXPOSE 8002

# 启动命令 - 使用自定义 FastAPI 服务
CMD ["python3", "whisper_server.py"]
