# Vision MCP Server Docker 镜像
FROM python:3.11-slim

WORKDIR /app

# MCP 服务只需最小依赖（不需要 pilk/pgvector/sentence-transformers 等重型包）
RUN pip install --no-cache-dir \
    anthropic>=0.39.0 \
    mcp>=0.9.0 \
    httpx==0.25.2 \
    python-dotenv==1.0.0 \
    pydantic-settings==2.1.0 \
    pydantic[email]==2.5.2 \
    -i https://pypi.tuna.tsinghua.edu.cn/simple

# 复制 MCP 服务器代码
COPY mcp_server/ ./mcp_server/
COPY app/config.py ./app/config.py
COPY app/services/vision_service.py ./app/services/vision_service.py
COPY app/core/llm.py ./app/core/llm.py

# 暴露端口（HTTP 模式时使用）
EXPOSE 8001

# 启动命令
CMD ["python", "-m", "mcp_server.server"]